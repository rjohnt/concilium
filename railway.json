{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "echo 'static — no build'",
    "nixpacksConfig": {
      "nodeVersion": "22"
    }
  },
  "deploy": {
    "startCommand": "npm start",
    "healthcheckPath": "/design-system.html",
    "restartPolicyType": "ON_FAILURE"
  }
}
