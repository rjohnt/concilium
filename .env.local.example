# Concilium environment — copy to .env.local and fill in. .env.local is gitignored.

# ── Supabase (auth + realtime + data layer) ───────────────────────────────────
# Public, safe to expose to the browser: used for auth, realtime, client reads.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only, NEVER expose to the client or commit. Enables the Postgres data
# layer (bypasses RLS). When absent, the server falls back to local SQLite
# (data/concilium.db) so dev/CI work with zero setup.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI (mediator, stand-ins, build specs) ─────────────────────────────────────
DEEPSEEK_API_KEY=your-deepseek-key

# ── Build executor (optional) ─────────────────────────────────────────────────
# "report" (default) | "local-claude" (runs the Claude Code CLI in a sandbox)
# CONCILIUM_BUILD_EXECUTOR=report
# CONCILIUM_BUILD_WORKSPACE=data/builds
